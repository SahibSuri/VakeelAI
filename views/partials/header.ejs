<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= typeof title !=='undefined' ? title : 'Legal AI Dashboard' %>
  </title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
    rel="stylesheet">

  <!-- Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

  <nav class="navbar">
    <div class="nav-container">
      <div href="/" class="logo">VakeelAI</div>
      <div class="nav-links">
        <a href="/" class="nav-link active">Last Month's Judgments</a>
        <a href="/" class="nav-link">Supreme Court</a>
        <a href="/" class="nav-link">High Courts</a>
        <a href="/" class="nav-link">Public Forum</a>
        <a href="/" class="nav-link">Trending</a>
      </div>

      <div class="nav-auth">
        <% if (user) { %>
          <span style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase;">Hello, <%= user.name %>
              </span>
          <form action="/api/auth/logout" method="POST" style="display:inline;">
            <button type="submit" class="btn btn-sm">Logout</button>
          </form>
          <% } else { %>
            <a href="/login" class="btn btn-sm">Log In</a>
            <a href="/register" class="btn btn-primary btn-sm">Sign Up</a>
            <% } %>
      </div>
    </div>
  </nav>

  <main class="main-content">